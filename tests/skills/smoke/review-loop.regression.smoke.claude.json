{
  "id": "review-loop.regression.smoke.claude",
  "type": "smoke",
  "target": "review-loop",
  "runtime": "claude",
  "requires": ["claude", "codex"],
  "setup": {
    "temp_config": "",
    "timeout_seconds": 1200
  },
  "execution_policy": "best_effort",
  "artifacts": {
    "capture": {
      "session_path": "latest_session",
      "session_final": "latest_session",
      "reviewer_prompt": "reviewer_prompt_file",
      "tool_use_events": "stream_json_read_events"
    },
    "required": [
      "session_path",
      "session_final",
      "tool_use_events",
      "assertions",
      "meta"
    ]
  },
  "command": [
    "claude",
    "-p",
    "--no-session-persistence",
    "--permission-mode",
    "bypassPermissions",
    "--add-dir",
    "__WORKTREE__",
    "--",
    "Use the repo skill review-loop to handle this task end-to-end: add one concise sentence to the Codex Stage 1 section of README.md clarifying that executor_model is ignored in Codex Stage 1 and codex_executor_model remains reserved. If the task is already satisfied, complete the loop as a no-op round rather than making a duplicate edit."
  ],
  "assertions": [
    "session_created",
    "review_loop_planning_or_review_only_route_recorded",
    "execution_or_noop_round_recorded",
    "entry_point_review_loop",
    "approved_plan_section_present",
    "completed_stages_ordered_exec_polish_docs_security",
    "delivery_blocked_by_null",
    "review_loop_protocol_imports_read"
  ]
}
