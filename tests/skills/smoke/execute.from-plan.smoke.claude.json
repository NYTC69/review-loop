{
  "id": "execute.from-plan.smoke.claude",
  "type": "smoke",
  "target": "execute",
  "runtime": "claude",
  "requires": [
    "claude",
    "codex"
  ],
  "setup": {
    "temp_config": "",
    "timeout_seconds": 120
  },
  "execution_policy": "best_effort",
  "artifacts": {
    "capture": {
      "session_path": "latest_session",
      "session_final": "latest_session",
      "reviewer_prompt": "reviewer_prompt_file",
      "tool_use_events": "stream_json_read_events"
    },
    "required": [
      "session_path",
      "session_final",
      "reviewer_prompt",
      "tool_use_events",
      "assertions",
      "meta"
    ]
  },
  "command": [
    "claude",
    "-p",
    "--no-session-persistence",
    "--permission-mode",
    "bypassPermissions",
    "--add-dir",
    "__WORKTREE__",
    "--",
    "Use the review-loop:execute skill with --stop-after exec-round --title \"user-supplied plan smoke\" --plan \"Trivial no-op plan: the repo already documents execute entry mode 2 behavior (plan body injected verbatim under the Approved Plan section with Source user-supplied). Treat current state as already satisfying this plan.\""
  ],
  "assertions": [
    "session_created",
    "execution_or_noop_round_recorded",
    "source_user_supplied_under_approved_plan",
    "entry_point_execute_from_plan",
    "reviewer_prompt_user_supplied_provenance_marker",
    "execute_protocol_imports_read",
    "no_forbidden_review_loop_subagent_types_in_agent_calls",
    {
      "id": "agent_calls_used_at_least_one_subagent",
      "overrides": {
        "min": 0,
        "_comment": "min: 0 \u2014 fixture currently truncates before Agent dispatch under the 120s cap; tighten to 1 after BACKLOG follow-up fortifies dispatch within budget"
      }
    },
    {
      "id": "agent_calls_use_general_purpose_subagent_type"
    }
  ]
}
