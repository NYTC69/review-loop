    },
    {
      "id": "codex_executor_model_semantics_target",
      "kind": "consistent_with",
      "mapping_id": "codex_executor_model"
    },
    {
      "id": "judgment_model_semantics_target",
      "kind": "consistent_with",
      "mapping_id": "judgment_model"
    },
    {
      "id": "cheap_model_semantics_target",
      "kind": "consistent_with",
      "mapping_id": "cheap_model"
    },
    {
