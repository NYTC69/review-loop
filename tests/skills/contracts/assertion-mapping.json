{
  "id": "assertion-mapping",
  "description": "Concrete smoke assertion meanings and cross-file consistency mappings for skill tests",
  "smoke_assertions": {
    "session_created": {
      "kind": "artifact_path_exists",
      "artifact": "session-path.txt",
      "needle": ".review-loop/sessions/"
    },
    "planning_round_recorded_numbered": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "### Planning Round 1"
    },
    "planning_round_recorded_roleform": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "### Round 1 — Planner"
    },
    "execution_round_recorded_roleform": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "### Round 1 — Executor"
    },
    "execution_round_recorded_numbered": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "### Execution Round 1"
    },
    "execution_round_recorded_appended_form": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "### Round 1 — Execution"
    },
    "reviewer_round_1_recorded_roleform": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "### Round 1 — Reviewer"
    },
    "reviewer_round_1_recorded_review_only_form": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "### Round 1 — Execution (review-only)"
    },
    "noop_execution_outcome_recorded": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "no-op execution round"
    },
    "reviewer_backend_codex": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- reviewer_backend: codex"
    },
    "reviewer_prompt_exists": {
      "kind": "artifact_exists",
      "artifact": "reviewer-prompt.txt"
    },
    "reviewer_prompt_user_supplied_provenance_marker_advisory_phrase": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "(plan_source: user-supplied — plan conformance is advisory/MINOR)"
    },
    "reviewer_prompt_user_supplied_provenance_marker_plan_source_key": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "plan_source: user-supplied"
    },
    "shared_config_path_mentioned": {
      "kind": "artifact_contains",
      "artifact": "response.txt",
      "needle": ".review-loop/config.md"
    },
    "shared_sessions_path_mentioned": {
      "kind": "artifact_contains",
      "artifact": "response.txt",
      "needle": ".review-loop/sessions/"
    },
    "reviewer_backend_default_mentioned": {
      "kind": "artifact_contains",
      "artifact": "response.txt",
      "needle": "Claude CLI reviewer"
    },
    "reviewer_backend_fallback_mentioned": {
      "kind": "artifact_contains",
      "artifact": "response.txt",
      "needle": "local Codex reviewer"
    },
    "plan_source_reviewer_approved": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- Source: reviewer-approved"
    },
    "plan_source_user_supplied": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- Source: user-supplied"
    },
    "plan_source_review_only": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- Source: review-only"
    },
    "review_only_sentinel_present": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "(none — review-only mode)"
    },
    "review_target_section_present": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "## Review Target"
    },
    "approved_plan_section_present": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "## Approved Plan"
    },
    "entry_point_plan": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "entry_point: plan"
    },
    "entry_point_execute_from_plan": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "entry_point: execute-from-plan"
    },
    "entry_point_review_only": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "entry_point: review-only"
    },
    "entry_point_review_loop": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "entry_point: review-loop"
    },
    "completed_stages_field_present": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "completed_stages:"
    },
    "completed_stages_contains_exec_token": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "exec"
    },
    "completed_stages_contains_polish_token": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "polish"
    },
    "delivery_section_absent": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "## Session Metadata"
    },
    "completed_stages_list_exec_polish_inline": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- completed_stages: [exec, polish]"
    },
    "completed_stages_list_exec_polish_block": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- completed_stages:\n  - exec\n  - polish\n- "
    },
    "completed_stages_list_exec_polish_docs_security_inline": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- completed_stages: [exec, polish, docs, security]"
    },
    "completed_stages_list_exec_polish_docs_security_block": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- completed_stages:\n  - exec\n  - polish\n  - docs\n  - security"
    },
    "delivery_blocked_by_null_literal": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- delivery_blocked_by: null"
    },
    "review_only_sentinel_line_1": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "(none — review-only mode)"
    },
    "review_only_sentinel_line_2": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "Scope: see `## Review Target` section below."
    },
    "review_target_smoke_token_present": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "REVIEW_TARGET_SMOKE_TOKEN"
    },
    "execute_round_1_reviewer_only_marker": {
      "kind": "artifact_contains",
      "artifact": "session-final.md",
      "needle": "- Executor backend: skipped (review-only first round)"
    }
  },
  "smoke_groups": {
    "planning_round_recorded": {
      "mode": "any",
      "members": [
        "planning_round_recorded_numbered",
        "planning_round_recorded_roleform"
      ]
    },
    "execution_round_recorded": {
      "mode": "any",
      "members": [
        "execution_round_recorded_roleform",
        "execution_round_recorded_numbered",
        "execution_round_recorded_appended_form"
      ]
    },
    "reviewer_round_1_recorded": {
      "mode": "any",
      "members": [
        "reviewer_round_1_recorded_roleform",
        "reviewer_round_1_recorded_review_only_form"
      ]
    },
    "reviewer_prompt_user_supplied_provenance_marker": {
      "mode": "any",
      "members": [
        "reviewer_prompt_user_supplied_provenance_marker_advisory_phrase",
        "reviewer_prompt_user_supplied_provenance_marker_plan_source_key"
      ]
    },
    "completed_stages_list_exec_polish": {
      "mode": "any",
      "members": [
        "completed_stages_list_exec_polish_inline",
        "completed_stages_list_exec_polish_block"
      ]
    },
    "completed_stages_list_exec_polish_docs_security": {
      "mode": "any",
      "members": [
        "completed_stages_list_exec_polish_docs_security_inline",
        "completed_stages_list_exec_polish_docs_security_block"
      ]
    },
    "execution_or_noop_round_recorded": {
      "mode": "any",
      "members": [
        "execution_round_recorded",
        "noop_execution_outcome_recorded"
      ]
    },
    "reviewer_backend_behavior_mentioned": {
      "mode": "all",
      "members": [
        "reviewer_backend_default_mentioned",
        "reviewer_backend_fallback_mentioned"
      ]
    },
    "completed_stages_contains_exec": {
      "mode": "all",
      "members": [
        "completed_stages_field_present",
        "completed_stages_contains_exec_token"
      ]
    },
    "completed_stages_contains_polish": {
      "mode": "all",
      "members": [
        "completed_stages_field_present",
        "completed_stages_contains_polish_token"
      ]
    },
    "completed_stages_ordered_exec_polish": {
      "mode": "all",
      "members": [
        "completed_stages_field_present",
        "completed_stages_list_exec_polish"
      ]
    },
    "completed_stages_ordered_exec_polish_docs_security": {
      "mode": "all",
      "members": [
        "completed_stages_field_present",
        "completed_stages_list_exec_polish_docs_security"
      ]
    },
    "delivery_blocked_by_null": {
      "mode": "all",
      "members": [
        "delivery_blocked_by_null_literal"
      ]
    },
    "review_only_sentinel_literal_two_line": {
      "mode": "all",
      "members": [
        "review_only_sentinel_line_1",
        "review_only_sentinel_line_2"
      ]
    },
    "review_target_section_has_scope_content": {
      "mode": "all",
      "members": [
        "review_target_section_present",
        "review_target_smoke_token_present"
      ]
    },
    "source_user_supplied_under_approved_plan": {
      "mode": "all",
      "members": [
        "approved_plan_section_present",
        "plan_source_user_supplied"
      ]
    },
    "execute_round_1_reviewer_only": {
      "mode": "all",
      "members": [
        "reviewer_round_1_recorded",
        "execute_round_1_reviewer_only_marker"
      ]
    }
  },
  "consistency_mappings": {
    "reviewer_model": [
      {
        "path": "review-loop-config.example.md",
        "needle": "reviewer_model: \"\"              # shared Claude/plugin key; in Codex Stage 1 this still applies to the default Claude CLI reviewer path"
      },
      {
        "path": "README.md",
        "needle": "`reviewer_model` controls the default Claude CLI reviewer"
      },
      {
        "path": ".agents/skills/guide/SKILL.md",
        "needle": "`reviewer_model` still applies to the Claude"
      },
      {
        "path": ".agents/skills/review-loop/SKILL.md",
        "needle": "`reviewer_model` applies only to the Claude CLI reviewer path."
      }
    ],
    "codex_reviewer_backend": [
      {
        "path": "review-loop-config.example.md",
        "needle": "# codex_reviewer_backend: claude_cli  # \"claude_cli\" | \"codex\""
      },
      {
        "path": "README.md",
        "needle": "`codex_reviewer_backend: codex` in `.review-loop/config.md`."
      },
      {
        "path": ".agents/skills/guide/SKILL.md",
        "needle": "You can force that fallback path with:"
      },
      {
        "path": ".agents/skills/guide/SKILL.md",
        "needle": "codex_reviewer_backend: codex"
      },
      {
        "path": ".agents/skills/review-loop/SKILL.md",
        "needle": "If `codex_reviewer_backend: codex` is present, skip the Claude path and use"
      }
    ],
    "codex_reviewer_model": [
      {
        "path": "review-loop-config.example.md",
        "needle": "# codex_reviewer_model: \"\"            # model override for Codex fallback reviewer"
      },
      {
        "path": "README.md",
        "needle": "and `codex_reviewer_model` overrides the model used by that Codex fallback"
      },
      {
        "path": ".agents/skills/guide/SKILL.md",
        "needle": "and use the Codex reviewer directly. In that case, `codex_reviewer_model` is"
      },
      {
        "path": ".agents/skills/review-loop/SKILL.md",
        "needle": "`codex_reviewer_model` applies only to the Codex fallback reviewer path."
      }
    ],
    "executor_model": [
      {
        "path": "review-loop-config.example.md",
        "needle": "executor_model: inherit         # shared Claude/plugin key; ignored by Codex Stage 1"
      },
      {
        "path": "README.md",
        "needle": "The `reviewer` and `executor_model` entries above still"
      },
      {
        "path": ".agents/skills/review-loop/SKILL.md",
        "needle": "`executor_model` is ignored by the Codex runtime in Stage 1."
      }
    ],
    "codex_executor_model": [
      {
        "path": "review-loop-config.example.md",
        "needle": "# codex_executor_model: \"\"            # shared key remains `executor_model`; this is reserved/ignored in Stage 1"
      },
      {
        "path": "README.md",
        "needle": "In Codex Stage 1, `executor_model` is ignored and `codex_executor_model` remains reserved."
      },
      {
        "path": ".agents/skills/review-loop/SKILL.md",
        "needle": "`codex_executor_model` is reserved only and ignored in Stage 1."
      }
    ],
    "executor_schema_parity": [
